# .env.example — template of required environment variables.
#
# Copy this file to `.env` and fill in the real values. Real credentials live ONLY
# in `.env`, which is gitignored and must never be committed.
#
# Nothing here is required to run the automations in --dry-run mode (mock clients).
# A live run of a given automation requires only the variables its systems use;
# each client's `config.require(...)` names the exact missing key if one is absent.
#
# See docs/CREDENTIALS.md for how to obtain each value.

# ---- ClickUp — the CRM (replaces Taskey) ----
# Personal token: ClickUp → avatar (bottom-left) → Settings → Apps → API Token →
# Generate. Starts with "pk_".
CLICKUP_BASE_URL=https://api.clickup.com/api/v2
CLICKUP_API_TOKEN=
# The list that holds one task per client. Open the list in the browser; the id is
# the number in the URL: app.clickup.com/<team>/v/li/<THIS_NUMBER>
CLICKUP_LIST_ID=
# Shared secret used to verify inbound ClickUp webhooks are genuine. Invent a long
# random string; ClickUp returns it when the webhook is registered.
CLICKUP_WEBHOOK_SECRET=
# Optional: command that starts Claude Code on a task brief (brief path appended).
CLAUDE_CODE_CMD=
CLAUDE_TASK_QUEUE_DIR=claude_task_queue

# ---- Morning (getmorning / חשבונית ירוקה) — invoices & payment requests ----
# app.greeninvoice.co.il → הגדרות → כללי → ממשק למתכנתים (API) → generate.
# The Secret is shown once only.
MORNING_BASE_URL=https://api.greeninvoice.co.il/api/v1
MORNING_API_KEY=
MORNING_API_SECRET=

# ---- Green API (WhatsApp) ----
# green-api.com → create an Instance → copy both values → scan the QR from the
# WhatsApp number that messages clients.
GREEN_API_BASE_URL=https://api.green-api.com
GREEN_API_ID_INSTANCE=
GREEN_API_TOKEN_INSTANCE=

# ---- Signing (our own signing page — replaces Fillout) ----
# Public HTTPS base URL where clients open their quote to sign. Must be reachable
# from the internet and hold a valid TLS certificate.
SIGN_BASE_URL=
# Long random string used to sign the per-quote links so they cannot be guessed or
# tampered with. Generate with: python -c "import secrets;print(secrets.token_urlsafe(48))"
SIGN_LINK_SECRET=

# ---- Google Workspace (Contacts / Drive / Forms) ----
# Path to the service-account JSON key file (keep it outside the repo).
GOOGLE_SERVICE_ACCOUNT_FILE=
# The Workspace user the service account impersonates (domain-wide delegation),
# e.g. dror@his-domain.co.il — needed because Contacts/Drive files must be owned
# by a real user, not the service account.
GOOGLE_IMPERSONATE_SUBJECT=
# Drive folder ids — open the folder; the id is the last part of the URL.
DRIVE_CLIENTS_PARENT_ID=
DRIVE_TEMPLATE_IDS=
DRIVE_DEFAULT_PARENT_ID=
QUESTIONNAIRE_URL=

# ---- Meta Ads — campaign numbers for the monthly report ----
# business.facebook.com → Business Settings → System Users → Generate Token with
# the ads_read permission.
META_BASE_URL=https://graph.facebook.com/v21.0
META_ACCESS_TOKEN=
# Ad account id including the "act_" prefix, e.g. act_1234567890
META_AD_ACCOUNT_ID=

# ---- Anthropic (Claude AI) ----
# console.anthropic.com → Settings → API Keys → Create Key. Starts with "sk-ant-".
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_KEY=

# ---- Recipients / misc ----
# International format, digits only, no "+" — e.g. 972501234567
DROR_WHATSAPP=
DROR_EMAIL=
RUN_LOG_PATH=logs/run_log.jsonl
WEBHOOK_PORT=8000
