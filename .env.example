# .env.example — template of required environment variables.
#
# Copy this file to `.env` and fill in the real values. Real credentials live ONLY
# in `.env`, which is gitignored and must never be committed.
#
# Nothing here is required to run the automations in --dry-run mode (mock clients).
# A live run of a given automation requires only the variables its systems use;
# each client's `config.require(...)` names the exact missing key if one is absent.
#
# See docs/CREDENTIALS.md for how to obtain each value.

# ---- ClickUp — the CRM (replaces Taskey) ----
# Personal token: ClickUp → avatar (bottom-left) → Settings → Apps → API Token →
# Generate. Starts with "pk_".
CLICKUP_BASE_URL=https://api.clickup.com/api/v2
CLICKUP_API_TOKEN=
# Workspace (team) id. Needed for Attachment custom fields, which upload through
# the workspace-scoped v3 API. Printed by: check_clickup_crm --discover
CLICKUP_TEAM_ID=
# The `לקוחות` list — one task per client. This is the CRM. Open the list in the
# browser; the id is the number in the URL: app.clickup.com/<team>/v/li/<THIS_NUMBER>
# Or run: python -m src.tools.check_clickup_crm --discover
CLICKUP_LIST_ID=
# The `משימות` list — one task per unit of work, linked to a client by the `לקוח`
# Relationship field. Watched by the ClickUp -> Claude Code bridge. Optional: leave
# empty if per-client tasks are not being managed in ClickUp.
CLICKUP_TASKS_LIST_ID=
# Verifies inbound ClickUp webhooks are genuine. ClickUp generates this when the
# webhook is registered — printed by src/tools/register_clickup_webhook.py.
CLICKUP_WEBHOOK_SECRET=
# Authenticates ClickUp Button presses. ClickUp does NOT sign Automation webhooks,
# so this header token is the only thing protecting an endpoint that sends quotes
# to clients. Generate with:
#   python -c "import secrets;print(secrets.token_urlsafe(32))"
# Then set it as the X-Automation-Token header in each button's Automation.
AUTOMATION_TOKEN=
# Optional: command that starts Claude Code on a task brief (brief path appended).
CLAUDE_CODE_CMD=
CLAUDE_TASK_QUEUE_DIR=claude_task_queue

# ---- ManyChat (WhatsApp via the official Meta Business API) ----
# ManyChat → Settings → API → "Generate your API Key". Needs a paid ManyChat plan.
# Note: once the number is connected to ManyChat it can ONLY be messaged through
# ManyChat's API — not through Meta's Cloud API directly.
MANYCHAT_BASE_URL=https://api.manychat.com
MANYCHAT_API_KEY=
# Outside the 24-hour customer-service window WhatsApp only delivers Meta-approved
# message templates, which ManyChat sends as Flows. One flow id per outbound
# message; find each under the flow's ⋯ menu. See docs/CREDENTIALS.md.
MANYCHAT_FLOW_QUESTIONNAIRE=
MANYCHAT_FLOW_QUOTE=
MANYCHAT_FLOW_PAYMENT=
MANYCHAT_FLOW_ONBOARDING=
MANYCHAT_FLOW_DAILY_SUMMARY=
# Meta requires proof of opt-in when a contact is created via the API. This phrase
# is recorded as that proof — it must describe how the client actually consented.
MANYCHAT_CONSENT_PHRASE=

# ---- Smoove → ManyChat webhook (find/create contact, then trigger a Flow) ----
# Smoove POSTs a lead — {"f_name","cellphone","msg"} — to the Smoove endpoint. The
# msg value picks the ManyChat Flow to send, by naming an env var: msg="ai_agents"
# resolves to MANYCHAT_FLOW_AI_AGENTS. Add a new message type by adding a new
# MANYCHAT_FLOW_<MSG> variable (uppercased, non-alphanumerics → "_"); no code change.
# An unmapped msg is rejected, not sent to a default.
MANYCHAT_FLOW_AI_AGENTS=
# Route by Smoove list: each list POSTs its list id as msg, which resolves to
# MANYCHAT_FLOW_<listid>. flow_ns is the content..._... part of the flow's ManyChat
# URL (…/cms/files/<flow_ns>/edit).
# list 1142673 → flow content20260723124130_896802
MANYCHAT_FLOW_1142673=
# list 889128  → flow content20260723124251_658385
MANYCHAT_FLOW_889128=
# Optional shared secret. Empty = the Smoove endpoint is OPEN (anyone who finds the
# URL can create contacts and fire billed Flows). Set it, and configure Smoove to
# send it as the X-Smoove-Token header (or ?token= in the URL), to require auth.
#   python -c "import secrets;print(secrets.token_urlsafe(32))"
SMOOVE_WEBHOOK_TOKEN=
# Country code prepended to local-format phones (a leading 0 trunk). 972 = Israel.
SMOOVE_DEFAULT_COUNTRY_CODE=972

# ---- Signing (our own signing page — replaces Fillout) ----
# Public HTTPS base URL where clients open their quote to sign. Must be reachable
# from the internet and hold a valid TLS certificate.
SIGN_BASE_URL=
# Long random string used to sign the per-quote links so they cannot be guessed or
# tampered with. Generate with: python -c "import secrets;print(secrets.token_urlsafe(48))"
SIGN_LINK_SECRET=

# ---- Google Workspace (Contacts / Drive / Forms) ----
# Step-by-step: docs/GOOGLE_SETUP.md. Verify with: python -m src.tools.check_google
#
# The service-account key. Use the JSON form in production — Lambda has no
# filesystem to read a key file from. Paste the whole file on one line.
# This key can act as Dror indefinitely: treat it like his password, and never
# commit it (this repo is public).
GOOGLE_SERVICE_ACCOUNT_JSON=
# Local development alternative: a path to the key file, kept OUTSIDE the repo.
GOOGLE_SERVICE_ACCOUNT_FILE=
# The Workspace user the service account acts as, via domain-wide delegation.
# Required: a service account has no Contacts of its own, and Drive files it
# creates would be owned by the robot rather than by Dror — invisible to him.
GOOGLE_IMPERSONATE_SUBJECT=
# Drive folder ids — open the folder; the id is the last part of the URL.
DRIVE_CLIENTS_PARENT_ID=
DRIVE_TEMPLATE_IDS=
DRIVE_DEFAULT_PARENT_ID=
QUESTIONNAIRE_URL=

# ---- Meta Ads — campaign numbers for the monthly report ----
# business.facebook.com → Business Settings → System Users → Generate Token with
# the ads_read permission. Assign EVERY client's ad account to that system user
# (Assign Assets), or a client whose account it can't see fails at report time.
META_BASE_URL=https://graph.facebook.com/v21.0
META_ACCESS_TOKEN=
# The real ad account is per-client: the חשבון מודעות Meta field on the ClickUp
# task. This global is used ONLY by `python -m src.tools.check_meta` as a default,
# and is deliberately NOT a fallback in the report — defaulting a client with no
# field to a shared account would put one client's spend in another's PDF.
META_AD_ACCOUNT_ID=
# Dror's business portfolio id (Business Settings → Business Info). Used by
# `python -m src.tools.sync_meta_accounts` to find newly-shared client accounts and
# assign them to the system user. That tool also needs the token to carry
# `business_management` in addition to ads_read.
META_BUSINESS_ID=

# ---- Anthropic (Claude AI) ----
# console.anthropic.com → Settings → API Keys → Create Key. Starts with "sk-ant-".
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_KEY=

# ---- AWS (hosts the webhooks, the signing page and the dashboard) ----
# Dror's AWS account. These are read explicitly rather than from ~/.aws, because
# the machine's ambient AWS profile may point at a different account entirely —
# a deploy against the wrong account is not something to leave to a default.
#
# Use an IAM user with only the permissions this stack needs, NOT the account
# root. Root keys cannot be scoped and cannot be rotated without breaking
# everything; if one leaks, the account and its billing go with it.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# eu-central-1 (Frankfurt). il-central-1 (Tel Aviv) is closer to Dror, but it is
# an opt-in region and must be enabled in the console before it can be used.
AWS_REGION=eu-central-1
# Set by the deploy; the public base URL API Gateway hands back.
AWS_API_BASE_URL=

# ---- Dashboard (read-only control panel) ----
# The dashboard shows client names, phones and prices, so it refuses to start
# without a password. Generate one with:
#   python -c "import secrets;print(secrets.token_urlsafe(24))"
DASHBOARD_PASSWORD=
DASHBOARD_PORT=8080
# Public URL of the dashboard, linked from the daily email.
DASHBOARD_URL=
# Set to 1 ONLY for local http development — it drops the Secure flag on the
# session cookie. Never set this in production.
DASHBOARD_INSECURE_COOKIE=

# ---- Email (daily report to Dror) ----
# For Gmail/Workspace: create an App Password (myaccount.google.com → Security →
# 2-Step Verification → App passwords) and use it as SMTP_PASSWORD. A normal
# account password will not work.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ---- The provider's own details (Dror's side of the contract) ----
# Deliberately NOT in templates/contract_he.html: this repo is public, and a bank
# account number in it is a fraud vector that cannot be recalled once indexed.
# The contract refuses to render if any of these are missing, rather than send a
# client an agreement with no account to pay into.
PROVIDER_NAME=דרור ברק
PROVIDER_BUSINESS_ID=
PROVIDER_ADDRESS=
PROVIDER_PHONE=
PROVIDER_EMAIL=
PROVIDER_BANK=
PROVIDER_BANK_BRANCH=
PROVIDER_BANK_ACCOUNT=

# ---- Recipients / misc ----
# International format, digits only, no "+" — e.g. 972501234567
DROR_WHATSAPP=
DROR_EMAIL=
RUN_LOG_PATH=logs/run_log.jsonl
WEBHOOK_PORT=8000
