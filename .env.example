# .env.example — template of required environment variables.
#
# Copy this file to `.env` and fill in the real values. Real credentials live ONLY
# in `.env`, which is gitignored and must never be committed.
#
# Nothing here is required to run the automations in --dry-run mode (mock clients).
# A live run of a given automation requires only the variables its systems use;
# each client's `config.require(...)` names the exact missing key if one is absent.

# ---- Taskey CRM (Open Question #1: API unconfirmed) ----
CRM_BASE_URL=
CRM_API_TOKEN=

# ---- Morning (getmorning / חשבונית ירוקה) ----
MORNING_BASE_URL=https://api.greeninvoice.co.il/api/v1
MORNING_API_KEY=
MORNING_API_SECRET=

# ---- Green API (WhatsApp) ----
GREEN_API_BASE_URL=https://api.green-api.com
GREEN_API_ID_INSTANCE=
GREEN_API_TOKEN_INSTANCE=

# ---- Fillout (digital signatures) ----
FILLOUT_BASE_URL=https://api.fillout.com/v1/api
FILLOUT_API_KEY=
FILLOUT_QUOTE_FORM_ID=

# ---- Google Workspace (Contacts / Drive / Forms) ----
# A short-lived OAuth / service-account access token (a real deployment refreshes
# it). See Open Question #6.
GOOGLE_ACCESS_TOKEN=
DRIVE_CLIENTS_PARENT_ID=
DRIVE_TEMPLATE_IDS=
DRIVE_DEFAULT_PARENT_ID=
QUESTIONNAIRE_URL=

# ---- ClickUp (bonus module) ----
CLICKUP_BASE_URL=https://api.clickup.com/api/v2
CLICKUP_API_TOKEN=
# Optional: command that starts Claude Code on a task brief (brief path appended).
CLAUDE_CODE_CMD=
CLAUDE_TASK_QUEUE_DIR=claude_task_queue

# ---- Anthropic (Claude AI) ----
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_KEY=

# ---- Recipients / misc ----
DROR_WHATSAPP=
RUN_LOG_PATH=logs/run_log.jsonl
WEBHOOK_PORT=8000
