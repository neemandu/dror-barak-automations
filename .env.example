# .env.example — template of required environment variables.
#
# Copy this file to `.env` and fill in the real values. Real credentials live ONLY
# in `.env`, which is gitignored and must never be committed.
#
# Nothing here is required to run the automations in --dry-run mode (mock clients).
# A live run of a given automation requires only the variables its systems use;
# each client's `config.require(...)` names the exact missing key if one is absent.
#
# See docs/CREDENTIALS.md for how to obtain each value.

# ---- ClickUp — the CRM (replaces Taskey) ----
# Personal token: ClickUp → avatar (bottom-left) → Settings → Apps → API Token →
# Generate. Starts with "pk_".
CLICKUP_BASE_URL=https://api.clickup.com/api/v2
CLICKUP_API_TOKEN=
# The `לקוחות` list — one task per client. This is the CRM. Open the list in the
# browser; the id is the number in the URL: app.clickup.com/<team>/v/li/<THIS_NUMBER>
# Or run: python -m src.tools.check_clickup_crm --discover
CLICKUP_LIST_ID=
# The `משימות` list — one task per unit of work, linked to a client by the `לקוח`
# Relationship field. Watched by the ClickUp -> Claude Code bridge. Optional: leave
# empty if per-client tasks are not being managed in ClickUp.
CLICKUP_TASKS_LIST_ID=
# Shared secret used to verify inbound ClickUp webhooks are genuine. Invent a long
# random string; ClickUp returns it when the webhook is registered.
CLICKUP_WEBHOOK_SECRET=
# Optional: command that starts Claude Code on a task brief (brief path appended).
CLAUDE_CODE_CMD=
CLAUDE_TASK_QUEUE_DIR=claude_task_queue

# ---- Morning (getmorning / חשבונית ירוקה) — invoices & payment requests ----
# app.greeninvoice.co.il → הגדרות → כללי → ממשק למתכנתים (API) → generate.
# The Secret is shown once only.
MORNING_BASE_URL=https://api.greeninvoice.co.il/api/v1
MORNING_API_KEY=
MORNING_API_SECRET=

# ---- ManyChat (WhatsApp via the official Meta Business API) ----
# ManyChat → Settings → API → "Generate your API Key". Needs a paid ManyChat plan.
# Note: once the number is connected to ManyChat it can ONLY be messaged through
# ManyChat's API — not through Meta's Cloud API directly.
MANYCHAT_BASE_URL=https://api.manychat.com
MANYCHAT_API_KEY=
# Outside the 24-hour customer-service window WhatsApp only delivers Meta-approved
# message templates, which ManyChat sends as Flows. One flow id per outbound
# message; find each under the flow's ⋯ menu. See docs/CREDENTIALS.md.
MANYCHAT_FLOW_QUESTIONNAIRE=
MANYCHAT_FLOW_QUOTE=
MANYCHAT_FLOW_PAYMENT=
MANYCHAT_FLOW_ONBOARDING=
MANYCHAT_FLOW_DAILY_SUMMARY=
# Meta requires proof of opt-in when a contact is created via the API. This phrase
# is recorded as that proof — it must describe how the client actually consented.
MANYCHAT_CONSENT_PHRASE=

# ---- Signing (our own signing page — replaces Fillout) ----
# Public HTTPS base URL where clients open their quote to sign. Must be reachable
# from the internet and hold a valid TLS certificate.
SIGN_BASE_URL=
# Long random string used to sign the per-quote links so they cannot be guessed or
# tampered with. Generate with: python -c "import secrets;print(secrets.token_urlsafe(48))"
SIGN_LINK_SECRET=

# ---- Google Workspace (Contacts / Drive / Forms) ----
# Path to the service-account JSON key file (keep it outside the repo).
GOOGLE_SERVICE_ACCOUNT_FILE=
# The Workspace user the service account impersonates (domain-wide delegation),
# e.g. dror@his-domain.co.il — needed because Contacts/Drive files must be owned
# by a real user, not the service account.
GOOGLE_IMPERSONATE_SUBJECT=
# Drive folder ids — open the folder; the id is the last part of the URL.
DRIVE_CLIENTS_PARENT_ID=
DRIVE_TEMPLATE_IDS=
DRIVE_DEFAULT_PARENT_ID=
QUESTIONNAIRE_URL=

# ---- Meta Ads — campaign numbers for the monthly report ----
# business.facebook.com → Business Settings → System Users → Generate Token with
# the ads_read permission.
META_BASE_URL=https://graph.facebook.com/v21.0
META_ACCESS_TOKEN=
# Ad account id including the "act_" prefix, e.g. act_1234567890
META_AD_ACCOUNT_ID=

# ---- Anthropic (Claude AI) ----
# console.anthropic.com → Settings → API Keys → Create Key. Starts with "sk-ant-".
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_KEY=

# ---- Dashboard (read-only control panel) ----
# The dashboard shows client names, phones and prices, so it refuses to start
# without a password. Generate one with:
#   python -c "import secrets;print(secrets.token_urlsafe(24))"
DASHBOARD_PASSWORD=
DASHBOARD_PORT=8080
# Public URL of the dashboard, linked from the daily email.
DASHBOARD_URL=
# Set to 1 ONLY for local http development — it drops the Secure flag on the
# session cookie. Never set this in production.
DASHBOARD_INSECURE_COOKIE=

# ---- Email (daily report to Dror) ----
# For Gmail/Workspace: create an App Password (myaccount.google.com → Security →
# 2-Step Verification → App passwords) and use it as SMTP_PASSWORD. A normal
# account password will not work.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ---- Recipients / misc ----
# International format, digits only, no "+" — e.g. 972501234567
DROR_WHATSAPP=
DROR_EMAIL=
RUN_LOG_PATH=logs/run_log.jsonl
WEBHOOK_PORT=8000
