# ---- Secrets ----
.env
.env.*
!.env.example

# Credential files. A Google service-account key downloads with a name like
# `dror-automations-f9fa4f55023e.json` and lands wherever the browser puts it —
# which was once this directory, one `git add -A` away from a public repo.
# Keys belong outside the repo entirely (~/.secrets/); these patterns are the
# backstop, not the plan.
*-????????????.json
*service*account*.json
*credentials*.json
client_secret*.json
*.pem
*.p12

# ---- Client material (kept on disk, never published) ----
# The repo is public. Dror's proposal, call notes and any client-supplied
# document stay local only.
# Dror's original contract text: it carries his bank account and ח.פ.
docs/contract_source.txt

docs/*.pdf
docs/*.docx
docs/*.xlsx

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
build/
dist/

# ---- Node.js ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dist/
coverage/

# ---- Build output ----
# `sam build` stages the function plus its dependencies here. Rebuilt on demand,
# and it copies the whole project, so it has no business in git.
.aws-sam/
samconfig.toml

# ---- Logs / misc ----
*.log
logs/
.DS_Store
Thumbs.db
